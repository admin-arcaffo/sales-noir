generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Organization {
  id                  String               @id @default(cuid())
  name                String
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  plan                String               @default("free")
  slug                String               @unique
  auditLogs           AuditLog[]
  contacts            Contact[]
  prompts             PromptTemplate[]
  users               User[]
  whatsappConnections WhatsAppConnection[]
  pipelineStages      PipelineStage[]
  products            Product[]
}

model User {
  id             String       @id @default(cuid())
  clerkId        String       @unique
  email          String       @unique
  name           String?
  organizationId String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  role           String       @default("member")
  analyses       AIAnalysis[]
  auditLogs      AuditLog[]
  tasks          Task[]
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model WhatsAppConnection {
  id                      String           @id @default(cuid())
  organizationId          String
  phoneNumberId           String?
  wabaId                  String?
  accessToken             String?
  status                  String           @default("DISCONNECTED")
  lastSyncAt              DateTime?
  createdAt               DateTime         @default(now())
  updatedAt               DateTime         @updatedAt
  instanceName            String?          @unique
  instanceToken           String?
  provider                String           @default("META")
  webhookSecret           String?
  connectionAttempts      Int              @default(0)
  lastConnectedAt         DateTime?
  lastConnectionAttemptAt DateTime?
  qrCodeCreatedAt         DateTime?
  integrationLogs         IntegrationLog[]
  organization            Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model Contact {
  id             String             @id @default(cuid())
  phone          String
  name           String
  organizationId String
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  company        String?
  email          String?
  interestArea   String?
  notes          String?
  origin         String?
  potentialValue Float?
  isLead         Boolean            @default(false)
  avatarUrl      String?
  monthlyRevenue Float?
  mainChallenges String?
  productId      String?
  product        Product?           @relation(fields: [productId], references: [id])
  organization   Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  conversations  Conversation[]
  leadHistory    LeadStageHistory[]
  tasks          Task[]

  @@unique([phone, organizationId])
}

model Product {
  id             String       @id @default(cuid())
  organizationId String
  name           String
  description    String?
  price          Float?
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  contacts       Contact[]
}

model PipelineStage {
  id             String       @id @default(cuid())
  organizationId String
  name           String
  color          String       @default("bg-zinc-500")
  order          Int          @default(0)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model Conversation {
  id            String       @id @default(cuid())
  contactId     String
  status        String       @default("OPEN")
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  lastMessageAt DateTime?
  outcome       String?
  stage         String       @default("PRIMEIRO_CONTATO")
  temperature   String       @default("COLD")
  analyses      AIAnalysis[]
  contact       Contact      @relation(fields: [contactId], references: [id], onDelete: Cascade)
  messages      Message[]
}

model Message {
  id             String           @id @default(cuid())
  conversationId String
  direction      String
  type           String
  content        String?
  mediaUrl       String?
  timestamp      DateTime         @default(now())
  waMessageId    String?          @unique
  isEdited       Boolean          @default(false)
  reactions      Json?
  transcript     AudioTranscript?
  media          Media?
  conversation   Conversation     @relation(fields: [conversationId], references: [id], onDelete: Cascade)
}

model Media {
  id          String   @id @default(cuid())
  messageId   String   @unique
  mimeType    String
  fileSize    Int?
  storageKey  String
  originalUrl String?
  createdAt   DateTime @default(now())
  message     Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
}

model AudioTranscript {
  id         String   @id @default(cuid())
  messageId  String   @unique
  text       String
  confidence Float?
  status     String   @default("PENDING")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  duration   Float?
  errorMsg   String?
  language   String?  @default("pt-BR")
  provider   String   @default("whisper")
  retries    Int      @default(0)
  message    Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
}

model AIAnalysis {
  id                 String           @id @default(cuid())
  conversationId     String
  userId             String
  summary            String
  painPoints         Json
  buyingSignals      Json
  createdAt          DateTime         @default(now())
  explicitObjections Json
  implicitObjections Json
  leadClassification String
  messageCount       Int?
  nextConcreteStep   String
  processingTimeMs   Int?
  recommendedPosture String
  riskLevel          String
  stage              String
  timeWindow         String?
  urgency            String
  whatToAvoid        String
  conversation       Conversation     @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user               User             @relation(fields: [userId], references: [id])
  suggestedReplies   SuggestedReply[]
}

model SuggestedReply {
  id            String     @id @default(cuid())
  analysisId    String
  type          String
  content       String
  wasUsed       Boolean    @default(false)
  wasEdited     Boolean    @default(false)
  editedContent String?
  createdAt     DateTime   @default(now())
  analysis      AIAnalysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)
}

model LeadStageHistory {
  id        String   @id @default(cuid())
  contactId String
  fromStage String
  toStage   String
  reason    String?
  changedBy String?
  createdAt DateTime @default(now())
  contact   Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
}

model Task {
  id          String    @id @default(cuid())
  contactId   String?
  userId      String
  title       String
  description String?
  type        String    @default("FOLLOW_UP")
  priority    String    @default("MEDIUM")
  status      String    @default("PENDING")
  dueAt       DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  contact     Contact?  @relation(fields: [contactId], references: [id])
  user        User      @relation(fields: [userId], references: [id])
}

model PromptTemplate {
  id             String       @id @default(cuid())
  organizationId String
  name           String
  content        String
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  category       String       @default("analysis")
  metadata       Json?
  slug           String
  version        Int          @default(1)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, slug, version])
}

model IntegrationLog {
  id           String             @id @default(cuid())
  connectionId String
  event        String
  direction    String?
  payload      Json?
  statusCode   Int?
  errorMsg     String?
  createdAt    DateTime           @default(now())
  connection   WhatsAppConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id             String       @id @default(cuid())
  organizationId String
  userId         String?
  action         String
  entity         String?
  entityId       String?
  metadata       Json?
  ipAddress      String?
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User?        @relation(fields: [userId], references: [id])
}
